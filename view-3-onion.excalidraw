    { "type": "text", "id": "cap", "x": 200, "y": 900, "width": 600, "height": 40, "text": "각 막은 모델의 '사고'를 건드리지 않고, 모델 바깥의 신뢰성 문제만 흡수한다.", "originalText": "각 막은 모델의 '사고'를 건드리지 않고, 모델 바깥의 신뢰성 문제만 흡수한다.", "fontSize": 14, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#475569", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 31045, "version": 1, "versionNonce": 31046, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.3 }
