    { "type": "text", "id": "loop_in_la", "x": 392, "y": 632, "width": 48, "height": 20, "text": "호출", "originalText": "호출", "fontSize": 13, "fontFamily": 3, "textAlign": "right", "verticalAlign": "middle", "strokeColor": "#6d28d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 10065, "version": 1, "versionNonce": 10066, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "lineHeight": 1.25 },
